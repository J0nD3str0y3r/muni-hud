# Copy this to .env.local and fill in your keys

# Mapbox public token — safe to expose to browser (map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Mapbox secret token — server-side only, needs DIRECTIONS:READ scope
# Create at account.mapbox.com/access-tokens → "Create a token" → check DIRECTIONS:READ
MAPBOX_SECRET_TOKEN=sk.your_secret_token_here

# 511 SF Bay — server-side only (arrivals/ETA panel)
SF_511_API_KEY=your_511_api_key_here

# Google Maps — server-side only, needs Directions API enabled
# console.cloud.google.com → APIs & Services → Directions API → Create credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
